{
  "compilerOptions": {
    // Build Performance
    "incremental": true,
    "composite": true,

    // Module System (Node.js app)
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@hcengineering/theme": ["node_modules/@hcengineering/theme/types/index.d.ts"],
      "@hcengineering/ui": ["node_modules/@hcengineering/ui/types/index.d.ts"],
      "@hcengineering/ui/src/types": ["node_modules/@hcengineering/ui/types/types.d.ts"]
    },

    // Import Handling
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,

    // Type Safety
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "types": ["node"],

    // Development
    "outDir": "dist",
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,

    // Effect Integration
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
